{
  "name": "quittance-backend",
  "version": "1.0.0",
  "description": "Stellar-based invoice system backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:mvp": "tsx watch src/server-mvp.ts",
