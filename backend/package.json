    "pg": "^8.11.3",
    "uuid": "^9.0.1",
    "zod": "^3.23.8",
    "bull": "^4.12.2",
    "ioredis": "^5.3.2",
    "nanoid": "^3.3.7",
    "qrcode": "^1.5.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.19",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/pg": "^8.11.0",
    "@types/uuid": "^9.0.8",
    "@types/qrcode": "^1.5.5",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
