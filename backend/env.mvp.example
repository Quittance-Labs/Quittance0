# MVP backend — no database. Copy to .env for local, or set in Render/Railway.

PORT=3001
NODE_ENV=production

STELLAR_NETWORK=TESTNET
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Optional placeholders (MVP uses per-invoice sellerPublicKey from the wallet)
SELLER_PUBLIC_KEY=
SELLER_SECRET_KEY=

# Must match the deployed frontend origin (CORS), no trailing slash
# Local:  http://localhost:3000
# Prod:   https://YOUR-APP.vercel.app
FRONTEND_URL=http://localhost:3000

# Local testing only — leave unset/false in production demos
ALLOW_SIMULATE=false
